# ─────────────────────────────────────────────────────────────────────────────
# HORDSTAKE BANK — Environment Variables
# Copy this file to .env for local dev, set directly on Render for production
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-very-secret-key-here-change-this-in-production

# Set to False in production
DEBUG=False

# Required on Render — set to your disk mount path
RENDER_DISK_PATH=/var/data

# Python version (Render uses this)
PYTHON_VERSION=3.11.0
